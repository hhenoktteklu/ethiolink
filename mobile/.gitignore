# Flutter / Dart build artifacts.
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
.pub-cache/
build/

# IDE / editor.
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Generated / per-platform scaffolding.
# The `flutter create` artifacts for each native target (ios/,
# linux/, macos/, web/, windows/) are NOT committed in this scaffold —
# `flutter create .` regenerates them locally on the operator's machine
# alongside the platform SDK they target. Commit only when a
# platform-specific override is required (e.g. iOS Info.plist edits for
# Cognito deep-link callbacks; that lives in a follow-up commit).
ios/
linux/
macos/
web/
windows/

# Android — we DO commit the project / app gradle files because they
# carry project-specific overrides (the `appAuthRedirectScheme`
# manifest placeholder, future flavor wiring, signing config). The
# usual transient Android build artifacts stay ignored:
android/.gradle/
android/captures/
android/local.properties
android/key.properties
android/**/build/
android/**/GeneratedPluginRegistrant.java
android/**/*.iml

# Local env files. The `dart-define-from-file` JSON files at
# `env/*.json` carry secrets-shaped values (Cognito client id) and
# stay out of git. `env/dev.example.json` is committed as the
# template.
env/dev.json
env/staging.json
env/prod.json

# Per-developer pubspec lock — Flutter convention is to commit
# pubspec.lock for apps. We commit it once the dependency tree
# stabilizes; until then keep it out so devs aren't churning the
# lockfile on every commit during the scaffold phase.
pubspec.lock

# `flutter gen-l10n` codegen output. Phase 9 Track 5 moved
# generated localizations from the synthetic `package:flutter_gen/...`
# layer (removed in Flutter 3.41) to the app's own
# `lib/generated/l10n/` directory. The files are derived from
# `lib/l10n/app_*.arb` and regenerated on every `flutter pub get`,
# so they don't belong in version control.
lib/generated/

# Coverage / test reports.
coverage/
test/.test_coverage.dart
