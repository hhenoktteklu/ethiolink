# EthioLink backend environment example. Copy to backend/.env for local dev.
# Never commit a real .env file.

# Runtime
NODE_ENV=development
LOG_LEVEL=info
APP_REGION=eu-west-1

# Postgres (local docker-compose defaults)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ethiolink
PG_USER=ethiolink
PG_PASSWORD=ethiolink
PG_SSL=false

# Cognito (filled in after Phase 1 Terraform apply)
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID_MOBILE=
COGNITO_APP_CLIENT_ID_ADMIN=
COGNITO_REGION=eu-west-1

# S3 (filled in after Phase 2 Terraform apply)
S3_BUCKET_MEDIA_PUBLIC=
S3_BUCKET_MEDIA_PRIVATE=
S3_UPLOAD_URL_EXPIRES_SECONDS=900
S3_READ_URL_EXPIRES_SECONDS=3600

# Adapters
NOTIFICATIONS_PROVIDER=mock
PAYMENTS_PROVIDER_CASH=cash
PAYMENTS_PROVIDER_ONLINE=mock

# Booking policy
BOOKING_CANCEL_CUTOFF_MINUTES=240
BOOKING_SLOT_STEP_MINUTES=15
BOOKING_BUFFER_MINUTES=5
DEFAULT_TIMEZONE=Africa/Addis_Ababa
