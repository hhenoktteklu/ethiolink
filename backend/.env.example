# EthioLink backend environment example. Copy to backend/.env for local dev.
# Never commit a real .env file.

# Runtime
NODE_ENV=development
LOG_LEVEL=info
APP_REGION=eu-west-1

# Postgres (local docker-compose defaults)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ethiolink
PG_USER=ethiolink
PG_PASSWORD=ethiolink
PG_SSL=false

# Cognito (filled in after Phase 1 Terraform apply)
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID_MOBILE=
COGNITO_APP_CLIENT_ID_ADMIN=
COGNITO_REGION=eu-west-1

# S3 (filled in after Phase 2 Terraform apply)
S3_BUCKET_MEDIA_PUBLIC=
S3_BUCKET_MEDIA_PRIVATE=
S3_UPLOAD_URL_EXPIRES_SECONDS=900
S3_READ_URL_EXPIRES_SECONDS=3600

# Adapters
NOTIFICATIONS_PROVIDER=mock
PAYMENTS_PROVIDER_CASH=cash
PAYMENTS_PROVIDER_ONLINE=mock

# Booking policy
BOOKING_CANCEL_CUTOFF_MINUTES=240
BOOKING_SLOT_STEP_MINUTES=15
BOOKING_BUFFER_MINUTES=5
DEFAULT_TIMEZONE=Africa/Addis_Ababa

# SMS provider (Phase 9 Track 1 — optional; set together to wire the real gateway)
# SMS_PROVIDER_API_BASE_URL=
# SMS_PROVIDER_API_KEY=
# SMS_PROVIDER_API_KEY_SECRET_ARN=
# SMS_PROVIDER_SENDER_ID=
# SMS_PROVIDER_NAME=GENERIC_SMS
# SMS_PROVIDER_TIMEOUT_MS=10000

# Telegram bot (Phase 9 Track 2 — optional; set together to enable Telegram
# linking + notifications). For dev set TELEGRAM_BOT_USERNAME +
# TELEGRAM_BOT_TOKEN + TELEGRAM_WEBHOOK_SECRET directly. The *_SECRET_ARN
# variants are the production wiring (Secrets Manager resolved via
# loadSecretsThenConfig).
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN_SECRET_ARN=
# TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_WEBHOOK_SECRET_ARN=
# TELEGRAM_PROVIDER_NAME=TELEGRAM_BOT
# TELEGRAM_LINK_CODE_TTL_SECONDS=600
# TELEGRAM_TIMEOUT_MS=10000
