<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application
        android:label="ethiolink"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!--
            Cognito hosted-UI callback handler.

            `flutter_appauth` declares its own
            `net.openid.appauth.RedirectUriReceiverActivity` in the
            plugin manifest with a scheme-only intent filter that
            reads `${appAuthRedirectScheme}` from
            `defaultConfig.manifestPlaceholders` (set to `ethiolink`
            in `android/app/build.gradle.kts`). In practice that
            filter alone wasn't routing the
            `ethiolink://auth/callback` redirect Cognito issues —
            Android returned the user to a closed Custom Tab and
            AppAuth surfaced `UserCancelledException` because no
            redirect Intent ever reached the app.

            Re-declaring `RedirectUriReceiverActivity` here with a
            full-URI filter (scheme + host + path) overrides the
            plugin's contribution via the `tools:node="replace"`
            merger directive and pins the exact callback shape from
            `mobile/env/dev.json`
            (`COGNITO_REDIRECT_URI=ethiolink://auth/callback`).

            If the redirect URI ever changes, update BOTH this filter
            AND the Cognito app client's callback list — they must
            match exactly.
        -->
        <activity
            android:name="net.openid.appauth.RedirectUriReceiverActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity="${applicationId}"
            android:noHistory="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.EthioLink.AppAuthRedirect"
            tools:node="replace">
            <!--
                `RedirectUriReceiverActivity` runs the OAuth response
                handoff from Custom Tabs back to AppAuth's
                `AuthorizationManagementActivity`. The launch
                attributes here are critical for the handoff:

                  * `launchMode="singleTask"` + `taskAffinity` of the
                    app's `${applicationId}` route the redirect back
                    into the SAME task that initiated sign-in. Without
                    this, the Custom Tab spawns the receiver in its
                    own task and AppAuth's stored state lookup fails
                    with `AppAuth: No stored state - unable to handle
                    response` — the state lives in the original
                    `AuthorizationManagementActivity` instance, which
                    only the original task can reach.

                  * `noHistory="true"` + `excludeFromRecents="true"`
                    keep the transient activity off the back stack
                    and out of the recents card — it's a one-shot
                    handoff, not something the user navigates to.

                  * Theme: `RedirectUriReceiverActivity` extends
                    `androidx.appcompat.app.AppCompatActivity`, which
                    asserts at `onCreate` that the inflated theme is
                    a `Theme.AppCompat` descendant. The Flutter
                    scaffold's default `LaunchTheme` / `NormalTheme`
                    extend `@android:style/Theme.Light.NoTitleBar`
                    (a platform theme), which previously crashed with
                    `IllegalStateException: You need to use a
                    Theme.AppCompat theme (or descendant)`.
                    `Theme.EthioLink.AppAuthRedirect` (defined in
                    `res/values/styles.xml`) extends
                    `Theme.AppCompat.NoActionBar` and is
                    fully-transparent so the receiver activity is
                    both AppCompat-compliant and visually invisible.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data
                    android:scheme="ethiolink"
                    android:host="auth"
                    android:path="/callback"/>
            </intent-filter>
        </activity>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
