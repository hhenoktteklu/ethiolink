    "appTagline": "Book salons, barbers, spas, and beauty pros across Ethiopia.",
    "@appTagline": {
        "description": "Subtitle under the brand mark on the login screen."
    },

    "loginSignIn": "Sign in",
    "@loginSignIn": {
        "description": "Primary action on the login screen that kicks off the Cognito PKCE flow."
